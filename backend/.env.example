# Copy this file to `.env` in this folder (`backend/.env`). Never commit `.env`.
# The API loads it automatically on startup (see `app/main.py`).

# Primary: Google Gemini (summary + audio/video transcription in this POC)
GEMINI_API_KEY=
# Alternative name (Google AI Studio often shows this):
# GOOGLE_API_KEY=

# Optional: model id (default gemini-2.5-flash; 2.0 Flash is not available for new API keys)
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_MODEL=gemini-2.5-pro

# Optional: max characters of transcript sent to the summarizer (default 900000; raise for very long meetings)
# GEMINI_SUMMARY_INPUT_CHARS=900000

# Optional fallback: OpenAI (only used if GEMINI_API_KEY is unset)
# OPENAI_API_KEY=
# OPENAI_SUMMARY_MODEL=gpt-4o-mini
# OPENAI_WHISPER_MODEL=whisper-1
