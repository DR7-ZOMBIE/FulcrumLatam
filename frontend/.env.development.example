# Copy to `.env.development`, restart `npm run dev`.

# Prefer direct API from the browser (avoids Vite proxy resets on long SSE / large files).
# Same host:port as your WSL uvicorn (default POC port 8787):
# VITE_API_URL=http://192.168.1.3:8787

# Mirrored WSL — used when VITE_API_URL is empty (relative /api → proxy):
# VITE_PROXY_API=http://192.168.1.3:8787

# Auto WSL IP + port (default 8787; override port with VITE_API_PORT=9000):
# VITE_USE_WSL_API=true

# API on Windows localhost only:
# VITE_USE_WSL_API=false
