# Copy to `.env.development`, restart `npm run dev`.

# Windows + Vite + API en WSL2: prefer 127.0.0.1 (WSL reenvía al puerto; la IP 192.168… cambia y da ETIMEDOUT).
# VITE_PROXY_API=http://127.0.0.1:8787

# Si 127.0.0.1 no conecta, pon la IP que salga de `wsl -e hostname -I` (la eth0/eth1 de WSL):
# VITE_PROXY_API=http://192.168.x.x:8787

# No VITE_API_URL por defecto (mismo origen /api → proxy). Opcional solo si sabes que te hace falta:
# VITE_API_URL=http://127.0.0.1:8787

# VITE_UPLOAD_TIMEOUT_MS=3600000

# Forzar IP LAN en Windows sin escribir VITE_PROXY_API a mano:
# VITE_USE_WSL_API=true
